/* ===== CodeHex Dynamic Theme Template ===== */

QWidget {
    background-color: {{BG_MAIN}};
    color: {{TEXT_MAIN}};
    font-family: "Outfit", "Inter", "Segoe UI", system-ui, sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-color: {{BG_DARKER}};
}

/* Glassmorphism Classes or IDs */
#toolbar, #chatBanner, #inputPanelContainer, #sidebarWidget {
    background-color: {{GLASS_BG}};
    border: 1px solid {{GLASS_BORDER}};
    border-radius: 16px;
    margin: 4px;
}

/* ---- Sidebar & Session List ---- */
#sidebarWidget {
    background-color: {{BG_MAIN}};
    border-right: 1px solid {{BORDER}};
}

#sessionList, #workFolderPanel {
    background-color: {{BG_WIDGET}};
    border: 1px solid {{GLASS_BORDER}};
    border-radius: 12px;
    margin: 8px;
    padding: 4px;
}

#sessionList::item {
    padding: 10px 12px;
    border-radius: 8px;
    color: {{TEXT_DIM}};
    margin: 2px 4px;
}

#sessionList::item:selected {
    background-color: {{ACCENT}};
    color: #FFFFFF;
    border: 1px solid {{ACCENT_HOVER}};
}

#sessionList::item:hover:!selected {
    background-color: {{BG_HOVER}};
}

#newSessionBtn, #newTaskBtn {
    background-color: transparent;
    border: none;
    color: {{ACCENT}};
    text-align: left;
    padding: 8px 16px;
    font-weight: 600;
}

#newSessionBtn:hover, #newTaskBtn:hover {
    background-color: {{BG_HOVER}};
    border-radius: 8px;
}

/* ---- Toolbar & Folder Selector ---- */
#toolbar {
    background-color: {{GLASS_BG}};
    border-bottom: 1px solid {{BORDER}};
    min-height: 48px;
}

#folderSelector {
    background-color: {{BG_WIDGET}};
    border: 1px solid {{BORDER}};
    border-radius: 8px;
    padding: 2px 10px;
    margin: 4px;
}

#profileCombo, #roleCombo, #modelCombo {
    background-color: {{BG_DARKER}};
    border: 1px solid {{BORDER}};
    border-radius: 8px;
    padding: 4px 12px;
    color: {{ACCENT}};
    font-weight: 500;
}

#profileCombo QAbstractItemView {
    background-color: {{BG_MAIN}};
    border: 1px solid {{ACCENT}};
    selection-background-color: {{ACCENT}};
}

/* ---- Splitters ---- */
QSplitter::handle {
    background-color: {{BORDER}};
}
QSplitter::handle:horizontal { width: 1px; }
QSplitter::handle:vertical { height: 1px; }

/* ---- TreeView (File Explorer) ---- */
QTreeView {
    background-color: transparent;
    border: none;
    color: {{TEXT_DIM}};
}
QTreeView::item {
    padding: 6px;
    border-radius: 4px;
}
QTreeView::item:hover {
    background-color: {{BG_HOVER}};
}
QTreeView::item:selected {
    background-color: {{ACCENT}};
    color: #FFFFFF;
}

/* ---- Chat View ---- */
QListView {
    background-color: {{BG_DARKER}};
    border: none;
    padding: 12px;
}

/* ---- Input Panel ---- */
#inputPanel {
    background-color: {{BG_MAIN}};
    border-top: 1px solid {{BORDER}};
    padding: 12px;
}

#inputTextEdit {
    background-color: {{BG_WIDGET}};
    border: 1px solid {{BORDER}};
    border-radius: 12px;
    padding: 10px;
    color: {{TEXT_MAIN}};
}

#inputTextEdit:focus {
    border-color: {{ACCENT}};
}

/* ---- Buttons ---- */
QPushButton {
    background-color: {{BG_WIDGET}};
    border: 1px solid {{BORDER}};
    border-radius: 8px;
    padding: 8px 20px;
    color: {{TEXT_MAIN}};
    font-weight: 500;
}

QPushButton:hover {
    background-color: {{BG_HOVER}};
    border-color: {{ACCENT}};
}

#sendBtn {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 {{ACCENT}}, stop:1 {{BG_DARKER}});
    border: 1px solid {{ACCENT_HOVER}};
    color: #FFFFFF;
    font-weight: bold;
}

#sendBtn:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 {{ACCENT_HOVER}}, stop:1 {{ACCENT}});
}

#stopBtn, #stopFloatingBtn {
    background-color: #450A0A;
    color: #FCA5A5;
    border: 1px solid #991B1B;
}

/* ---- Status bar & Progress ---- */
QStatusBar {
    background-color: {{BG_MAIN}};
    color: {{TEXT_DIM}};
    border-top: 1px solid {{BORDER}};
    font-size: 11px;
}

QProgressBar {
    border: 1px solid {{BORDER}};
    border-radius: 4px;
    background: {{BG_DARKER}};
    text-align: center;
}
QProgressBar::chunk {
    background-color: {{ACCENT}};
    border-radius: 3px;
}

/* ---- Scroll bars ---- */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
}
QScrollBar::handle:vertical {
    background: {{BORDER}};
    border-radius: 4px;
    min-height: 40px;
}
QScrollBar::handle:vertical:hover {
    background: {{ACCENT}};
}
