/* ===== CodeHex Premium Amber Theme ===== */

QWidget {
    background-color: #1A1612; /* Deep Obsidian Brown */
    color: #E2E2E2;
    font-family: "Outfit", "Inter", "Segoe UI", system-ui, sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-color: #140F0A; 
}

/* Glassmorphism & Glows */
#chatBanner, #sessionList, #workFolderPanel {
    background-color: rgba(35, 28, 22, 0.6);
    border: 1px solid rgba(217, 119, 6, 0.15);
    border-radius: 12px;
}

#chatBanner {
    border-bottom: 2px solid rgba(217, 119, 6, 0.3);
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 rgba(45, 35, 25, 0.8), stop:1 rgba(26, 22, 18, 0.6));
}

/* ---- Session Panel & Left Sidebar ---- */
#sidebarWidget {
    background-color: #1A1612;
    border-right: 1px solid #2D241C;
}

#sessionList, #workFolderPanel {
    background-color: rgba(30, 24, 18, 0.4);
    border: 1px solid rgba(217, 119, 6, 0.1);
    margin: 8px;
}

#sessionList::item {
    padding: 10px 12px;
    border-radius: 8px;
    color: #B4B4B4;
    margin: 2px 4px;
}

#sessionList::item:selected {
    background-color: rgba(217, 119, 6, 0.2);
    border: 1px solid rgba(217, 119, 6, 0.5);
    color: #FBBF24;
}

#sessionList::item:hover:!selected {
    background-color: rgba(255, 255, 255, 0.05);
}

/* Special Sidebar Buttons */
#newSessionBtn, #newTaskBtn {
    background-color: transparent;
    border: none;
    color: #FBBF24;
    text-align: left;
    padding: 8px 16px;
    font-weight: 500;
    font-size: 14px;
}

#newSessionBtn:hover, #newTaskBtn:hover {
    color: #FDE68A;
    background-color: rgba(217, 119, 6, 0.1);
    border-radius: 6px;
}

/* Fox Icon Sidebar Container */
#foxIconLabel {
    margin: 20px;
    border-radius: 40px;
    /* We handle the actual image in code */
}

/* ---- Sidebar Toggle ---- */
#sidebarToggleBtn {
    background: transparent;
    border: none;
    color: #6B7280;
    font-size: 11px;
    border-radius: 4px;
}
#sidebarToggleBtn:hover {
    background: rgba(255,255,255,0.07);
    color: #E2E2E2;
}

/* ---- Toolbar ---- */
#toolbar {
    background-color: rgba(35, 28, 22, 0.92);
    border: none;
    border-bottom: 1px solid #2D241C;
    border-radius: 0;
    min-height: 50px;
}

#profileCombo, #roleCombo {
    background-color: #2D241C;
    border: 1px solid #45362B;
    border-radius: 8px;
    padding: 4px 12px;
    color: #FBBF24;
}

#profileCombo::drop-down, #roleCombo::drop-down {
    border: none;
}

QComboBox QAbstractItemView {
    background-color: #2D241C;
    border: 1px solid #D97706;
    selection-background-color: #D97706;
    color: #E2E2E2;
}

/* ---- Chat View & Bubbles ---- */
QListView {
    background-color: #140F0A;
    border: none;
}

QListView::item {
    background: transparent;
}

QListView::item:selected,
QListView::item:hover {
    background: transparent;
}

/* Note: MessageDelegate handles complex bubble painting, but we hint colors here */
#chatView {
    background-color: #140F0A;
}

/* Tool Call Blocks (The 'Call: Bash' look) */
.ToolCallBlock {
    background-color: rgba(217, 119, 6, 0.05);
    border: 1px solid rgba(217, 119, 6, 0.3);
    border-radius: 10px;
    padding: 10px;
    color: #FBBF24;
}

/* ---- Input Panel ---- */
#inputPanel {
    background-color: #1A1612;
    border-top: 1px solid #2D241C;
    min-height: 80px;
    max-height: 360px;
}

#inputTextEdit {
    background-color: rgba(45, 35, 25, 0.6);
    border: 1px solid #45362B;
    border-radius: 12px;
    padding: 10px;
    color: #E2E2E2;
}

#inputTextEdit:focus {
    border-color: #D97706;
}

/* ---- Buttons ---- */
QPushButton {
    background-color: #2D241C;
    border: 1px solid #45362B;
    border-radius: 8px;
    padding: 8px 16px;
    color: #E2E2E2;
}

QPushButton:hover {
    background-color: #3D3126;
    border-color: #D97706;
}

#sendBtn {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #D97706, stop:1 #92400E);
    border-color: #B45309;
    color: #140F0A;
    font-weight: bold;
}

#sendBtn:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #F59E0B, stop:1 #D97706);
}

#stopBtn {
    background-color: #450A0A;
    border-color: #7F1D1D;
    color: #FCA5A5;
}

/* Floating Navigation Buttons */
#magnetBtn, #scrollDownBtn, #stopFloatingBtn {
    background-color: rgba(45, 35, 25, 0.95);
    border: 2px solid rgba(217, 119, 6, 0.7);
    border-radius: 20px;
    color: #FBBF24;
    font-size: 18px;
    font-weight: bold;
}

#magnetBtn:hover, #scrollDownBtn:hover {
    background-color: rgba(69, 54, 43, 0.98);
    border-color: #D97706;
}

#stopFloatingBtn:hover {
    background-color: rgba(127, 29, 29, 0.98);
    border-color: #EF4444;
    color: #FCA5A5;
}

#magnetBtn:checked {
    background-color: #D97706;
    border-color: #F59E0B;
    color: #140F0A;
}

/* Status Bar & Cauldron Footer (Phase 52) */
#statusBar {
    background: transparent;
    border-top: 1px solid rgba(217, 119, 6, 0.2);
    min-height: 140px;
}

#statusBar::item {
    border: none;
}

#tokenLabel {
    color: #6B7280;
    font-size: 11px;
    margin-right: 20px;
    padding-bottom: 20px; /* Push it down slightly or center */
}

#agentStatusLabel {
    background-color: rgba(26, 22, 18, 0.9);
    border: 1px solid #D97706;
    color: #FBBF24;
    border-radius: 12px;
    padding: 6px 16px;
    font-weight: 600;
    margin-left: 20px;
}

/* Terminal & Progress */
#terminalPanel {
    background-color: #0F0B08;
    border-top: 1px solid #D97706;
}

QProgressBar {
    border: 1px solid #45362B;
    border-radius: 6px;
    background: #1A1612;
    text-align: center;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #D97706, stop:1 #F59E0B);
    border-radius: 5px;
}

/* ---- Scroll bars ---- */
QScrollBar:vertical {
    background: transparent;
    width: 10px;
}

QScrollBar::handle:vertical {
    background: #45362B;
    border-radius: 5px;
    min-height: 30px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: #D97706;
}
